# 投资管理系统 - 环境变量配置示例
# Investment Manager - Environment Variables Example

# 飞书应用凭证
# 请在飞书开放平台创建应用后获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书 App Access Token
# 通过飞书 API 获取的 tenant_access_token
FEISHU_APP_ACCESS_TOKEN=

# 服务器端口
PORT=3000

# 行情同步时间 (默认: 每个交易日 21:30)
# MARKET_SYNC_CRON=30 21 * * 1-5

# 提醒功能 (暂时禁用)
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx
